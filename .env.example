# OpenAI / AI Provider API Key
# Leave empty for DEMO mode (returns mock grading/chat responses).
OPENAI_API_KEY=

# AI Model name (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Optional: Custom API base URL (for OpenAI-compatible providers)
# OPENAI_BASE_URL=

# Optional: JWT secret key (default: smit-ta-secret-key-change-in-production)
# JWT_SECRET_KEY=your-secret-key-here
